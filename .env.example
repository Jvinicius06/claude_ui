# ===== Authentication (choose ONE option) =====

# Option A: API Key (pay-as-you-go billing)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Option B: OAuth Login (uses your Claude Pro/Team subscription)
# Leave ANTHROPIC_API_KEY empty and run:
#   docker compose run --rm claude-code-ui login
# This saves your OAuth credentials in the persistent volume.

# ===== Optional Settings =====
# SERVER_PORT=3001
# CONTEXT_WINDOW=160000
